{
  "schema_version": 1,
  "owners": {
    "python_graph": "architecture",
    "native_runtime": "windows-platform",
    "plugin_runtime": "plugin-platform"
  },
  "versions": {
    "config_schema": 1,
    "plugin_sdk": "1.0",
    "plugin_protocol": "1.0"
  },
  "entry_modes": {
    "gui": "main.py",
    "plugin_helper": "main.py --plugin-helper",
    "plugin_worker": "main.py --plugin-worker",
    "smoke_test": "main.py --smoke-test"
  },
  "build_targets": [
    "scripts/build_win11_setup.bat",
    "scripts/build_encrypted.bat"
  ],
  "required_packages": [
    "application",
    "bootstrap",
    "core",
    "domain",
    "extensions",
    "hooks",
    "infrastructure",
    "modules",
    "services",
    "ui"
  ],
  "external_packages": ["numpy"],
  "hidden_imports": [
    "_hashlib",
    "_ssl",
    "ctypes.wintypes",
    "encodings.idna",
    "stringprep",
    "PIL.BmpImagePlugin",
    "PIL.GifImagePlugin",
    "PIL.IcoImagePlugin",
    "PIL.Image",
    "PIL.ImageDraw",
    "PIL.ImageFilter",
    "PIL.ImageFont",
    "PIL.JpegImagePlugin",
    "PIL.PngImagePlugin",
    "PIL.WebPImagePlugin",
    "pynput.keyboard._win32",
    "pynput.mouse._win32",
    "PyQt5.QtSvg",
    "psutil",
    "pythoncom",
    "qrcode",
    "ssl",
    "win32api",
    "win32com.client",
    "win32com.shell.shell",
    "win32con",
    "win32con",
    "win32event",
    "win32gui",
    "win32process",
    "win32ui"
  ],
  "data_files": [
    {"source": "assets", "target": "assets", "owner": "ui"},
    {"source": "third_party_licenses.json", "target": "third_party_licenses.json", "owner": "release-engineering"},
    {"source": "hooks/hooks.dll", "target": "hooks/hooks.dll", "owner": "windows-platform"},
    {"source": "native/QLcrypto/QLcrypto.dll", "target": "native/QLcrypto.dll", "owner": "crypto-platform"},
    {"source": "native/QLsearch/QLsearch.dll", "target": "native/QLsearch.dll", "owner": "search-platform"},
    {"source": "native/QLwindow/QLwindow.dll", "target": "native/QLwindow.dll", "owner": "windows-platform"},
    {"source": "native/QLwatch/QLwatch.dll", "target": "native/QLwatch.dll", "owner": "windows-platform"},
    {"source": "native/QLvalidate/QLvalidate.dll", "target": "native/QLvalidate.dll", "owner": "network-security"},
    {"source": "native/QLautostart/QLautostart.dll", "target": "native/QLautostart.dll", "owner": "windows-platform"},
    {"source": "native/QLupdate/QLupdate.dll", "target": "native/QLupdate.dll", "owner": "update-system"},
    {"source": "native/QLclipboard/QLclipboard.dll", "target": "native/QLclipboard.dll", "owner": "windows-platform"},
    {"source": "native/QLicon/QLicon.dll", "target": "native/QLicon.dll", "owner": "ui-platform"},
    {"source": "native/QLshell/QLshell.dll", "target": "native/QLshell.dll", "owner": "windows-platform"}
  ],
  "qt_plugins": ["platforms"],
  "plugin_storage": {
    "package_source": ".plugins/*.qlzip",
    "runtime_target": "plugins",
    "bundle_source_plugins": false
  },
  "forbidden_runtime_paths": [
    ".plugins",
    "plugins/PLUGIN_DEV.md",
    "tests",
    ".git"
  ],
  "provenance_manifest": "third_party_licenses.json"
}
